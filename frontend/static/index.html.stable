<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 中转站监控面板</title>
  <link rel="stylesheet" href="style.css?v=5">
</head>
<body>
  <header class="topbar">
    <h1>AI 中转站监控</h1>
    <div class="actions">
      <div class="search-wrapper">
        <input type="text" id="search-input" placeholder="搜索中转站..." autocomplete="off">
        <div id="search-results" class="search-results-dropdown"></div>
      </div>
      <button id="btn-toggle-all" class="btn-secondary">折叠全部</button>
      <span class="status-dot dot-ok" style="box-shadow: 0 0 8px rgba(74, 222, 128, 0.5);" title="监控守护中"></span>
      <button id="btn-refresh" class="btn-primary">手动刷新</button>
      <span id="last-updated" class="time-label">--</span>
    </div>
  </header>

  <main class="container">
    <section id="summary" class="summary-bar">
      <div class="stat">
        <span class="stat-num" id="stat-total">--</span>
        <span class="stat-label">站点</span>
      </div>
      <div class="stat">
        <span class="stat-num ok" id="stat-ok">--</span>
        <span class="stat-label">在线</span>
      </div>
      <div class="stat">
        <span class="stat-num warn" id="stat-warn">--</span>
        <span class="stat-label">需验证 <span class="stat-arrow">▼</span></span>
      </div>
      <div class="stat">
        <span class="stat-num" id="stat-low">--</span>
        <span class="stat-label">异常 <span class="stat-arrow">▼</span></span>
      </div>
    </section>

    <div id="stat-detail-dropdown" class="stat-dropdown-panel"></div>

    <section id="anomaly-section" class="anomaly-section" style="display:none">
      <h2 class="section-title">⚠ 需验证 / 异常</h2>
      <div id="anomaly-list" class="grid"></div>
    </section>

    <section>
      <h2 class="section-title">已验证在线</h2>
      <div id="station-list" class="grid">
        <div class="loading">加载中...</div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <span id="db-path"></span>
  </footer>

  <script src="app.js"></script>
</body>
</html>
